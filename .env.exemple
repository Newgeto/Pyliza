# Token du bot Discord (onglet "Bot" sur discord.com/developers/applications)
DISCORD_TOKEN=

# ID de l'application (onglet "General Information")
CLIENT_ID=

# ID du serveur Discord où déployer les commandes
GUILD_ID=

# URL d'Ollama (http://localhost:11434 en local, http://ollama:11434 via Docker)
OLLAMA_HOST=http://localhost:11434
